# Audio processing service configuration template.
#
# Copy this file to config.ini and edit for your environment:
#     cp config.ini.example config.ini
#
# config.ini is intentionally git-ignored: it holds per-deployment values.
# For multi-instance machines, point the [output] callbacks at the instance's
# Flask server port (DC_PORT) and give each instance its own redis_db
# (must match the server's redis_db). The websocket listen port is set with
# the DC_AUDIO_WS_PORT env var at launch (default 9000).

[processing]
# Speech-to-text backend:
#   google-cloud-speech  (default; PROPRIETARY paid API; needs google-cloud-key.json)
#   whisper              (faster-whisper; MIT, open, offline; pip install faster-whisper)
asr=google-cloud-speech

# Expression & Thinking Style scorer:
#   liwc  (default; uses the PROPRIETARY LIWC2007 dictionary + Harvard GI)
#   open  (Harvard General Inquirer only; fully open, offline, no license)
#   llm   (Google Gemini; PROPRIETARY paid API; needs GOOGLE_API_KEY)
#
# For a fully open-source, zero-license, offline pipeline use:
#   asr=whisper  and  scorer=open
scorer=liwc

keyword_model_limit=20000

# Keyword semantic matching backend:
#   word2vec   (2013 GoogleNews-300 static vectors; large, dated)
#   embedding  (default; a modern SentenceTransformer — better semantics,
#              vocabulary-free. Model + threshold set below.)
keyword_backend=embedding
keyword_embedding_model=BAAI/bge-small-en-v1.5
# Cosine-distance cutoff for the embedding backend (lower = stricter). Tighter
# than the word2vec 0.6 because sentence-embedding distances sit in a higher band.
keyword_embedding_threshold=0.28

# Fallback clustering for the post-hoc no-fingerprint path. NOTE: distinct from
# the per-run 'diarizer' field the trigger UI sends (fingerprint|pyannote),
# which decides whether the ASR runs pyannote at all. This decides what the
# fallback clustering does with any labels produced:
#   spectral  (2020 ECAPA + spectral clustering)
#   pyannote  (default; reuse pyannote 3.1 labels carried by the WhisperX/Qwen3
#             batch ASR — falls back to spectral when none are present, e.g.
#             the google/live ASR path)
diarization_fallback=pyannote
# When a pod's enrolled participants are known, cap pyannote diarization at the
# enrolled count (max_speakers) and remap each cluster onto its nearest enrolled
# voice print, so utterances resolve to real people instead of leftover
# SPEAKER_NN clusters. WhisperX/Qwen3 (batch ASR) paths only.
diarization_constrain_to_enrolled=false

# Live-path sentence embedder for participation/cohesion metrics:
#   all-mpnet-base-v2  (default; light, comparable with historical metrics)
#   bge-large-en-v1.5  (open SOTA; matches the post-hoc default)
semantic_embedder=all-mpnet-base-v2

# Whisper settings (used by the whisper / whisperx ASR backends).
# Post-hoc is latency-tolerant, so a large model is worthwhile:
#   model_size=large-v3         (most accurate)
#   model_size=distil-large-v3  (~2x faster, near-large accuracy)
#   model_size=small.en         (fastest, lowest accuracy — old default)
# compute_type=float16 on ample-VRAM GPUs; int8 to save memory.
[whisper]
model_size=large-v3
device=auto
compute_type=float16

[output]
processing_callback=http://127.0.0.1:5000/api/v1/callback/transcript
connect_callback=http://127.0.0.1:5000/api/v1/callback/connect
disconnect_callback=http://127.0.0.1:5000/api/v1/callback/disconnect
tagging_callback=http://127.0.0.1:5000/api/v1/callback/tag
speaker_metrics_callback=http://127.0.0.1:5000/api/v1/callback/speaker_transcript_metrics

[redis]
# Must match the server instance's redis_db (session auth/config keys live there).
#redis_host=localhost
#redis_port=6379
redis_db=0

[record]
original=false
reduced=false
recording_folder=recordings

[videorecord]
original=true
reduced=false
video_recording_folder=videorecordings

[videocartoonize]
cartoonize = false

[rootpath]
root_dir=/var/lib/

[biometrics]
biometrics_folder=audiobiometrics
