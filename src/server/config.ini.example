# BLINC server configuration template.
#
# Copy this file to config.ini and edit for your environment:
#     cp config.ini.example config.ini
#
# config.ini is intentionally git-ignored: it holds per-deployment values
# (domain, paths) and per-instance isolation settings. Multiple instances can
# share one machine by giving each its own database_name, redis_db, and
# root_dir (plus DC_PORT / DC_DEVICE_WS_PORT env vars at launch; the processors
# take DC_AUDIO_WS_PORT / DC_VIDEO_WS_PORT).

[server]
# true behind HTTPS/AWS, false for local dev.
https=false
debug=true

# Public host:port the frontend is served from. Accepts a comma-separated
# list when one instance serves several hostnames (each becomes an allowed
# SocketIO CORS origin), e.g. domain=example.com,dashboard.example.org
domain=localhost:3000

# MySQL user (password is derived as user:user) and database name.
# Give each instance its own database to isolate schema/migrations.
database_user=vagrant
database_name=discussion_capture

# Redis connection. Defaults: localhost:6379, db 0.
# Give each instance a distinct redis_db to isolate the SocketIO message
# queue and helper keys from other instances on the same Redis server.
#redis_host=localhost
#redis_port=6379
redis_db=0

[rootpath]
# Base directory for runtime file storage (biometrics, etc.).
# Point each instance at its own path to avoid clobbering shared files.
root_dir=/var/lib

# Optional cross-instance student-profile syncing. Leave this section out (or
# either value blank) to disable it entirely: no data leaves this instance,
# the inbound sync endpoint rejects all requests, and the People page hides
# the "Sync profiles" action. To mirror students with a peer BLINC deployment,
# set its base URL and a shared secret that BOTH instances must match.
#[sync]
#peer_url=https://peer.example.org
#token=change-me-to-a-long-random-string
