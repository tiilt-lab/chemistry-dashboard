# Video processing service configuration template.
#
# Copy this file to config.ini and edit for your environment:
#     cp config.ini.example config.ini
#
# config.ini is intentionally git-ignored: it holds per-deployment values.
# For multi-instance machines, point the [output] callbacks at the instance's
# Flask server port (DC_PORT) and give each instance its own redis_db
# (must match the server's redis_db). The websocket listen port is set with
# the DC_VIDEO_WS_PORT env var at launch (default 9003).

[output]
cartoonize_image_callback=http://127.0.0.1:5000/api/v1/session/addcartoonizedimage
video_metrics_callback=http://127.0.0.1:5000/api/v1/callback/speakervideometrics
connect_callback=http://127.0.0.1:5000/api/v1/callback/connect
disconnect_callback=http://127.0.0.1:5000/api/v1/callback/disconnect
redis_get_session_key_callback=http://127.0.0.1:5000/api/v1/sessions/getredissessionkey
redis_get_session_config_callback=http://127.0.0.1:5000/api/v1/sessions/getredissessionconfig

[redis]
# Must match the server instance's redis_db (session auth/config keys live there).
#redis_host=localhost
#redis_port=6379
redis_db=0

[videorecord]
original=true
reduced=false
video_recording_folder=videorecordings

[facialembedding]
facial_embedding_folder=facial_embeddings

[videocartoonize]
cartoonize = true

[videoanalyics]
processvideoanalytics = true

[rootpath]
root_dir=/var/lib/

[videoprocessing]
; Facial-emotion backend: hsemotion (EfficientNet-B2, AffectNet-8, open SOTA)
; or resmasking (ResMaskingNet, FER-2013).
emotion_model=hsemotion
; Object-of-focus detector: yolo11 (open SOTA) or yolov4 (original weights).
object_model=yolo11
; Gaze/attention backend: gazelle (Gaze-LLE, open SOTA) or gazefollow (2020 weights).
attention_model=gazelle
; Frames/second sampled by post-hoc video analysis (lower = faster, coarser).
posthoc_fps=12
